# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nestle_smartflow
MYSQL_TEST_DATABASE=nestle_smartflow_test
MYSQL_ROOT_PASSWORD=

# JWT Configuration
JWT_SECRET=replace-me
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=replace-me
REFRESH_TOKEN_EXPIRATION=7d

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@nestlesmartflow.com

# Logging
LOG_LEVEL=info

# Session Secret
SESSION_SECRET=replace-me